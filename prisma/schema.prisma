generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  name           String?
  timezone       String?
  distanceUnit   DistanceUnit @default(MI)
  pressureUnit   PressureUnit @default(PSI)
  emailVerified  DateTime?
  image          String?
  selectedBikeId String?
  bikes          Bike[]    @relation("UserOwnedBikes")
  selectedBike   Bike?     @relation("UserSelectedBike", fields: [selectedBikeId], references: [id], onDelete: SetNull)
  stravaConnection StravaConnection?
  notificationPreference UserNotificationPreference?
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime  @default(now())
}

model Bike {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation("UserOwnedBikes", fields: [userId], references: [id])
  selectedByUsers User[]   @relation("UserSelectedBike")
  name            String
  brand           String?
  model           String?
  year            Int?
  type            String?
  frameSize       String?
  frameMaterial   String?
  drivetrain      String?
  brakeType       String?
  wheelset        String?
  tireSetup       String?
  notes           String?
  isArchived      Boolean  @default(false)

  components        Component[]
  rides             Ride[]
  maintenanceEvents MaintenanceEvent[]
  pressureSetups    TirePressureSetup[]
  fitMeasurements   FitMeasurement[]
  checklistItems    ChecklistItem[]
  stravaImports     StravaActivityImport[]
  notificationPreferences BikeNotificationPreference[]
  maintenanceNotificationLogs MaintenanceNotificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Component {
  id             String          @id @default(cuid())
  bikeId         String
  bike           Bike            @relation(fields: [bikeId], references: [id])
  type           ComponentType
  name           String
  brand          String?
  model          String?
  installDate    DateTime?
  initialMileage Float           @default(0)
  currentMileage Float           @default(0)
  status         ComponentStatus @default(ACTIVE)
  notes          String?
  isActive       Boolean         @default(true)

  maintenanceEvents MaintenanceEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ride {
  id              String   @id @default(cuid())
  bikeId          String
  bike            Bike     @relation(fields: [bikeId], references: [id])
  date            DateTime
  distanceMiles   Float
  durationMinutes Int?
  rideType        RideType @default(OUTDOOR)
  weather         String?
  roadCondition   String?
  wasWet          Boolean  @default(false)
  notes           String?
  stravaImport    StravaActivityImport?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceEvent {
  id               String               @id @default(cuid())
  bikeId           String
  bike             Bike                 @relation(fields: [bikeId], references: [id])
  componentId      String?
  component        Component?           @relation(fields: [componentId], references: [id])
  type             MaintenanceEventType
  date             DateTime
  mileageAtService Float?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TirePressureSetup {
  id               String   @id @default(cuid())
  bikeId           String
  bike             Bike     @relation(fields: [bikeId], references: [id])
  name             String
  riderWeightLbs   Float
  bikeWeightLbs    Float
  gearWeightLbs    Float?
  frontTireWidthMm Int
  rearTireWidthMm  Int
  tubeless         Boolean
  surface          String
  preference       String
  frontPsi         Float
  rearPsi          Float
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FitMeasurement {
  id               String   @id @default(cuid())
  bikeId           String
  bike             Bike     @relation(fields: [bikeId], references: [id])
  date             DateTime
  saddleHeightMm   Float?
  saddleSetbackMm  Float?
  saddleTiltDeg    Float?
  stemLengthMm     Float?
  handlebarWidthMm Float?
  crankLengthMm    Float?
  spacerStackMm    Float?
  reachToHoodsMm   Float?
  cleatNotes       String?
  notes            String?
  isCurrent        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistItem {
  id        String   @id @default(cuid())
  bikeId    String
  bike      Bike     @relation(fields: [bikeId], references: [id])
  label     String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StravaConnection {
  id                  String           @id @default(cuid())
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stravaAthleteId     BigInt           @unique
  username            String?
  firstName           String?
  lastName            String?
  accessToken         String
  refreshToken        String
  tokenType           String           @default("Bearer")
  scope               String
  expiresAt           DateTime
  lastSyncAt          DateTime?
  lastSyncImportedCount Int            @default(0)
  lastSyncStatus      StravaSyncStatus @default(CONNECTED)
  lastSyncError       String?
  activityImports     StravaActivityImport[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model StravaActivityImport {
  id                 String           @id @default(cuid())
  stravaConnectionId String
  stravaConnection   StravaConnection @relation(fields: [stravaConnectionId], references: [id], onDelete: Cascade)
  stravaActivityId   String
  bikeId             String
  bike               Bike             @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  rideId             String?          @unique
  ride               Ride?            @relation(fields: [rideId], references: [id], onDelete: SetNull)
  activityName       String?
  activityType       String?
  startedAt          DateTime
  distanceMeters     Float?
  movingTimeSeconds  Int?
  importedAt         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([stravaConnectionId, stravaActivityId])
}

model UserNotificationPreference {
  id                   String                     @id @default(cuid())
  userId               String                     @unique
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationsEnabled Boolean                    @default(true)
  emailEnabled         Boolean                    @default(true)
  smsEnabled           Boolean                    @default(false)
  phoneNumber          String?
  bikePreferences      BikeNotificationPreference[]
  deliveryLogs         MaintenanceNotificationLog[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
}

model BikeNotificationPreference {
  id                           String                     @id @default(cuid())
  userNotificationPreferenceId String
  userNotificationPreference   UserNotificationPreference @relation(fields: [userNotificationPreferenceId], references: [id], onDelete: Cascade)
  userId                       String
  bikeId                       String
  bike                         Bike                       @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  enabled                      Boolean                    @default(true)
  emailEnabled                 Boolean                    @default(true)
  smsEnabled                   Boolean                    @default(false)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  @@unique([userId, bikeId])
  @@index([userNotificationPreferenceId])
  @@index([bikeId])
}

model MaintenanceNotificationLog {
  id                           String                     @id @default(cuid())
  userNotificationPreferenceId String
  userNotificationPreference   UserNotificationPreference @relation(fields: [userNotificationPreferenceId], references: [id], onDelete: Cascade)
  userId                       String
  bikeId                       String
  bike                         Bike                       @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  dueKey                       String
  dueStatus                    String
  channel                      NotificationChannel
  dayKey                       String
  deliveryStatus               NotificationDeliveryStatus @default(PENDING)
  attemptedAt                  DateTime                   @default(now())
  deliveredAt                  DateTime?
  errorMessage                 String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  @@unique([userId, bikeId, dueKey, channel, dayKey])
  @@index([bikeId, dayKey])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum ComponentType {
  CHAIN
  CASSETTE
  FRONT_TIRE
  REAR_TIRE
  FRONT_BRAKE_PAD
  REAR_BRAKE_PAD
  FRONT_ROTOR
  REAR_ROTOR
  CHAINRINGS
  CLEATS
  BAR_TAPE
  DI2_BATTERY
  PEDALS
  WHEELSET
  CRANKSET
  HANDLEBAR
  STEM
  SADDLE
  OTHER
}

enum ComponentStatus {
  ACTIVE
  REPLACED
  RETIRED
}

enum RideType {
  OUTDOOR
  INDOOR
  RACE
  GROUP_RIDE
  TRAINING
  RECOVERY
  LONG_RIDE
}

enum MaintenanceEventType {
  LUBED_CHAIN
  CLEANED_CHAIN
  CHECKED_CHAIN_WEAR
  REPLACED_CHAIN
  CHECKED_TIRE_PRESSURE
  INSPECTED_TIRE
  REPLACED_TIRE
  INSPECTED_BRAKE_PADS
  REPLACED_BRAKE_PADS
  CHARGED_DI2
  CHECKED_BOLTS
  FIT_ADJUSTMENT
  REPLACED_COMPONENT
  OTHER
}

enum StravaSyncStatus {
  CONNECTED
  SUCCESS
  NO_NEW_DATA
  ERROR
}

enum DistanceUnit {
  MI
  KM
}

enum PressureUnit {
  PSI
  BAR
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationDeliveryStatus {
  PENDING
  DELIVERED
  SKIPPED
  ERROR
}
